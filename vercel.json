{
	"version": 2,
	"builds": [
		{
			"src": "apps/web/package.json",
			"use": "@vercel/static-build",
			"config": {
				"distDir": "apps/web/.output/public"
			}
		}
	],
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "/(.*)",
			"dest": "/apps/web/.output/server/index.mjs"
		}
	],
	"buildCommand": "bun install && bunx turbo build --filter=@habitutor/api --filter=@habitutor/db --filter=@habitutor/auth && bunx turbo build --filter=web",
	"outputDirectory": "apps/web/.output/public",
	"installCommand": "bun install",
	"framework": null
}
